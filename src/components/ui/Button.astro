---
interface Props {
	href: string;
	variant?: 'primary' | 'secondary' | 'link';
	class?: string;
}

const { href, variant = 'primary', class: className = '' } = Astro.props;

const base =
	'type-btn inline-flex items-center justify-center rounded-full px-[30px] py-[14px] tracking-wide transition-all duration-300 ease-out focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2';

const variants = {
	primary:
		'bg-brand-red text-brand-white shadow-[0_4px_14px_-2px_rgba(185,28,56,0.35)] hover:-translate-y-0.5 hover:bg-brand-red-dark hover:shadow-[0_8px_20px_-4px_rgba(185,28,56,0.4)] focus-visible:outline-brand-red',
	secondary:
		'border border-brand-charcoal/20 bg-brand-white/80 text-brand-espresso shadow-sm backdrop-blur-sm hover:-translate-y-0.5 hover:border-brand-red/30 hover:bg-brand-ivory hover:shadow-md focus-visible:outline-brand-red',
	link: 'type-body-sm rounded-none px-0 py-0 !font-semibold text-brand-red underline-offset-4 shadow-none hover:-translate-y-0 hover:text-brand-red-dark hover:underline focus-visible:outline-brand-red',
};
---

<a href={href} class:list={[base, variants[variant], className]}>
	<slot />
</a>
