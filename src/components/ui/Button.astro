---
interface Props {
	href: string;
	variant?: 'primary' | 'secondary' | 'link';
	class?: string;
	arrow?: boolean;
}

const { href, variant = 'primary', class: className = '', arrow = true } = Astro.props;

const base =
	'type-btn inline-flex items-center justify-center gap-2 rounded-full px-[30px] py-[14px] tracking-wide transition-[transform,background-color,border-color,box-shadow,color] duration-300 ease-out focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2';

const variants = {
	primary:
		'btn-premium bg-brand-red text-brand-white shadow-[0_4px_14px_-2px_rgba(185,28,56,0.35)] hover:-translate-y-0.5 hover:bg-brand-red-dark hover:shadow-[0_8px_22px_-4px_rgba(185,28,56,0.38)] focus-visible:outline-brand-red',
	secondary:
		'btn-premium border border-brand-charcoal/20 bg-brand-white/80 text-brand-espresso shadow-sm backdrop-blur-sm hover:-translate-y-0.5 hover:border-brand-red/30 hover:bg-brand-ivory hover:shadow-md focus-visible:outline-brand-red',
	link: 'type-body-sm link-arrow rounded-none px-0 py-0 !font-semibold text-brand-red underline-offset-4 shadow-none hover:-translate-y-0 hover:text-brand-red-dark hover:underline focus-visible:outline-brand-red',
};

const showArrow = arrow && variant !== 'link';
---

<a href={href} class:list={[base, variants[variant], className]}>
	<span class="relative z-[1]"><slot /></span>
	{
		showArrow && (
			<svg
				class="btn-arrow relative z-[1] h-3.5 w-3.5 shrink-0"
				fill="none"
				viewBox="0 0 24 24"
				stroke="currentColor"
				aria-hidden="true"
			>
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
			</svg>
		)
	}
</a>
