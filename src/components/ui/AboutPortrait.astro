---
interface Props {
	src: string;
	alt: string;
	name: string;
	title: string;
}

const { src, alt, name, title } = Astro.props;
---

<figure class="mx-auto w-full max-w-xs sm:max-w-sm lg:mx-0 lg:max-w-none">
	<div
		class="overflow-hidden rounded-2xl border border-brand-taupe/25 bg-brand-warm shadow-[0_12px_40px_-12px_rgba(44,36,32,0.18)]"
	>
		<img
			src={src}
			alt={alt}
			width={640}
			height={800}
			class="aspect-[4/5] w-full object-cover object-[center_15%]"
			loading="lazy"
			decoding="async"
		/>
	</div>
	<figcaption class="mt-5 px-1 text-center sm:mt-6 lg:text-left">
		<p class="font-serif text-[1.25rem] leading-snug text-brand-espresso">{name}</p>
		<p class="type-caption mt-1.5 text-brand-charcoal/80">{title}</p>
	</figcaption>
</figure>
