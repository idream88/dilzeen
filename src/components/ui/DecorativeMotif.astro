---
interface Props {
	variant?: 'compass' | 'grid' | 'circles';
	class?: string;
}

const { variant = 'compass', class: className = '' } = Astro.props;
---

{
	variant === 'compass' && (
		<svg
			class:list={['pointer-events-none absolute text-brand-espresso/[0.06]', className]}
			viewBox="0 0 200 200"
			fill="none"
			aria-hidden="true"
		>
			<circle cx="100" cy="100" r="90" stroke="currentColor" stroke-width="0.5" />
			<circle cx="100" cy="100" r="60" stroke="currentColor" stroke-width="0.5" />
			<circle cx="100" cy="100" r="30" stroke="currentColor" stroke-width="0.5" />
			<line x1="100" y1="10" x2="100" y2="190" stroke="currentColor" stroke-width="0.5" />
			<line x1="10" y1="100" x2="190" y2="100" stroke="currentColor" stroke-width="0.5" />
			<line x1="36" y1="36" x2="164" y2="164" stroke="currentColor" stroke-width="0.3" />
			<line x1="164" y1="36" x2="36" y2="164" stroke="currentColor" stroke-width="0.3" />
			<polygon points="100,18 104,28 96,28" fill="currentColor" opacity="0.5" />
		</svg>
	)
}

{
	variant === 'grid' && (
		<svg
			class:list={['pointer-events-none absolute text-brand-espresso/[0.05]', className]}
			viewBox="0 0 120 120"
			fill="none"
			aria-hidden="true"
		>
			<rect x="10" y="10" width="100" height="100" stroke="currentColor" stroke-width="0.5" />
			<line x1="10" y1="43" x2="110" y2="43" stroke="currentColor" stroke-width="0.4" />
			<line x1="10" y1="77" x2="110" y2="77" stroke="currentColor" stroke-width="0.4" />
			<line x1="43" y1="10" x2="43" y2="110" stroke="currentColor" stroke-width="0.4" />
			<line x1="77" y1="10" x2="77" y2="110" stroke="currentColor" stroke-width="0.4" />
			<rect x="43" y="43" width="34" height="34" stroke="currentColor" stroke-width="0.6" />
		</svg>
	)
}

{
	variant === 'circles' && (
		<svg
			class:list={['pointer-events-none absolute text-brand-rose/30', className]}
			viewBox="0 0 160 160"
			fill="none"
			aria-hidden="true"
		>
			<circle cx="80" cy="80" r="70" stroke="currentColor" stroke-width="0.5" />
			<circle cx="80" cy="80" r="50" stroke="currentColor" stroke-width="0.4" opacity="0.6" />
			<circle cx="80" cy="80" r="30" stroke="currentColor" stroke-width="0.3" opacity="0.4" />
		</svg>
	)
}
