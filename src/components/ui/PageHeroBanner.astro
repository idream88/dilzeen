---
import DecorativeMotif from './DecorativeMotif.astro';
import type { StockImage } from '../../data/images';

interface Props {
	title: string;
	subtitle?: string;
	image: StockImage;
	overlay?: 'light' | 'warm' | 'cream';
}

const { title, subtitle, image, overlay = 'warm' } = Astro.props;

const overlayClasses = {
	light: 'from-brand-cream/92 via-brand-cream/78 to-brand-cream/45',
	warm: 'from-brand-cream/95 via-brand-cream/85 to-brand-cream/50',
	cream: 'from-brand-cream/97 via-brand-cream/90 to-brand-cream/60',
};
---

<section class="relative overflow-hidden">
	<div class="absolute inset-0">
		<img
			src={image.src}
			alt=""
			class="h-full w-full object-cover"
			style={`object-position: ${image.objectPosition ?? 'center center'}`}
			aria-hidden="true"
		/>
		<div class:list={['absolute inset-0 bg-gradient-to-r', overlayClasses[overlay]]}></div>
		<div class="absolute inset-0 bg-gradient-to-t from-brand-cream via-transparent to-brand-ivory/30"></div>
	</div>

	<DecorativeMotif variant="compass" class="right-8 top-16 h-40 w-40 opacity-40 sm:right-16 sm:h-56 sm:w-56" />
	<DecorativeMotif variant="grid" class="bottom-20 right-1/3 h-20 w-20 opacity-50" />

	<div class="relative mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24 lg:px-8 lg:py-28">
		<div class="max-w-3xl" data-reveal-stagger>
			<h1 class="text-4xl font-semibold tracking-tight text-brand-black sm:text-5xl" data-reveal data-reveal-immediate>{title}</h1>
			{subtitle && <p class="mt-4 max-w-2xl text-lg text-brand-black/70" data-reveal data-reveal-immediate>{subtitle}</p>}
		</div>
	</div>

	<div
		class="pointer-events-none absolute -bottom-px left-0 right-0 h-12 bg-gradient-to-b from-transparent to-brand-cream"
		aria-hidden="true"
	></div>
</section>
