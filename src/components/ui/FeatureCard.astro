---
interface Props {
	title: string;
	description: string;
	icon: 'local' | 'relocation' | 'investor' | 'holistic';
	index: number;
}

const { title, description, icon, index } = Astro.props;

const offsets = ['lg:translate-y-0', 'lg:translate-y-4', 'lg:-translate-y-2', 'lg:translate-y-6'];
const offset = offsets[index % offsets.length];
---

<article
	data-reveal="fade"
	class:list={[
		'card-lift group relative rounded-2xl border border-brand-taupe/50 bg-brand-ivory/80 p-7 backdrop-blur-sm',
		offset,
	]}
>
	<div
		class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl border border-brand-beige bg-brand-cream text-brand-red transition-colors duration-300 group-hover:border-brand-red/20 group-hover:bg-brand-rose/20"
	>
		{
			icon === 'local' && (
				<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
					<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
				</svg>
			)
		}
		{
			icon === 'relocation' && (
				<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" />
				</svg>
			)
		}
		{
			icon === 'investor' && (
				<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
				</svg>
			)
		}
		{
			icon === 'holistic' && (
				<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
					<circle cx="12" cy="12" r="9" />
					<path stroke-linecap="round" d="M12 3v18M3 12h18" />
					<circle cx="12" cy="12" r="3" />
				</svg>
			)
		}
	</div>
	<h3 class="text-xl leading-snug">{title}</h3>
	<div class="mt-3 h-px w-8 bg-brand-red/40 transition-all duration-300 group-hover:w-12"></div>
	<p class="type-body-sm mt-4">{description}</p>
</article>
