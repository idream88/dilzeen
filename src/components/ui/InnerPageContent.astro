---
import PageHero from './PageHero.astro';
import PageHeroBanner from './PageHeroBanner.astro';
import AboutPortrait from './AboutPortrait.astro';
import AboutCredentials from './AboutCredentials.astro';
import StockImage from './StockImage.astro';
import CTABanner from '../sections/CTABanner.astro';
import type { PageContent } from '../../data/placeholders';

interface Props {
	content: PageContent;
}

const { content } = Astro.props;
---

{
	content.heroImage ? (
		<PageHeroBanner title={content.title} subtitle={content.subtitle} image={content.heroImage} />
	) : (
		<PageHero title={content.title} subtitle={content.subtitle} />
	)
}

<section class="py-16 sm:py-20">
	<div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
		{
			content.portrait ? (
				<div class="grid items-start gap-10 sm:gap-12 lg:grid-cols-12 lg:gap-x-16">
					<div class="order-2 lg:order-1 lg:col-span-7" data-reveal>
						<div class="prose prose-lg max-w-none text-brand-black/80">
							{content.intro.map((paragraph) => (
								<p class="type-body mb-5 last:mb-0">{paragraph}</p>
							))}
						</div>
					</div>
					<div class="order-1 lg:order-2 lg:col-span-5 lg:pt-2" data-reveal>
						<AboutPortrait {...content.portrait} />
					</div>
				</div>
			) : content.introImage ? (
				<div class="grid items-start gap-10 sm:gap-12 lg:grid-cols-12 lg:gap-x-16">
					<div class="order-2 lg:order-1 lg:col-span-7" data-reveal>
						<div class="prose prose-lg max-w-none text-brand-black/80">
							{content.intro.map((paragraph) => (
								<p class="type-body mb-5 last:mb-0">{paragraph}</p>
							))}
						</div>
					</div>
					<div class="order-1 lg:order-2 lg:col-span-5 lg:pt-2" data-reveal>
						<div class="relative">
							<div
								class="absolute -right-2 -top-2 h-full w-full rounded-2xl border border-brand-taupe/30"
								aria-hidden="true"
							/>
							<StockImage image={content.introImage} aspect="aspect-[4/5]" overlay />
						</div>
					</div>
				</div>
			) : (
				<div class="prose prose-lg max-w-3xl text-brand-black/80" data-reveal>
					{content.intro.map((paragraph) => (
						<p class="mb-4">{paragraph}</p>
					))}
				</div>
			)
		}

		{content.credentials && <AboutCredentials {...content.credentials} />}

		{
			content.supportingImages && content.supportingImages.length > 0 && (
				<div
					class:list={[
						'mt-14',
						content.supportingImages.length === 1
							? 'mx-auto max-w-4xl'
							: 'grid gap-6 sm:grid-cols-2',
						content.supportingImages.length === 3 && 'lg:grid-cols-3',
					]}
					data-reveal-stagger
				>
					{content.supportingImages.map((image) => (
						<div class="relative" data-reveal>
							<div
								class="absolute -right-2 -top-2 h-full w-full rounded-2xl border border-brand-taupe/30"
								aria-hidden="true"
							/>
							<StockImage image={image} aspect="aspect-[16/10]" overlay />
						</div>
					))}
				</div>
			)
		}

		{
			content.features.length > 0 && (
				<div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3" data-reveal-stagger>
					{content.features.map((feature) => (
						<div data-reveal class="card-lift rounded-lg border border-brand-black/10 bg-brand-warm p-6">
							<h2 class="text-lg font-semibold text-brand-black">{feature.title}</h2>
							<p class="mt-2 text-sm text-brand-black/70">{feature.description}</p>
						</div>
					))}
				</div>
			)
		}

		{
			content.accentSection && (
				<div class="mt-16 grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
					<div data-reveal>
						<p class="type-eyebrow">{content.accentSection.eyebrow}</p>
						<h2 class="mt-4 text-2xl font-semibold text-brand-black sm:text-3xl">
							{content.accentSection.title}
						</h2>
						<div class="accent-line mt-5"></div>
						<p class="type-body mt-6 text-brand-black/80">{content.accentSection.description}</p>
					</div>
					<div class="relative" data-reveal>
						<div
							class="absolute -left-2 -bottom-2 h-full w-full rounded-2xl border border-brand-taupe/30"
							aria-hidden="true"
						/>
						<StockImage image={content.accentSection.image} aspect="aspect-[4/3]" overlay />
					</div>
				</div>
			)
		}

		{
			content.steps && content.steps.length > 0 && (
				<div class="mt-16" data-reveal>
					<h2 class="text-2xl font-semibold text-brand-black">How It Works</h2>
					<ol class="mt-8 grid gap-8 sm:grid-cols-3" data-reveal-stagger>
						{content.steps.map((step, i) => (
							<li data-reveal>
								<span class="flex h-8 w-8 items-center justify-center rounded-full bg-brand-red text-sm font-semibold text-brand-white">
									{i + 1}
								</span>
								<h3 class="mt-4 text-lg font-semibold text-brand-black">{step.title}</h3>
								<p class="type-body-sm mt-2 text-brand-black/85">{step.description}</p>
							</li>
						))}
					</ol>
				</div>
			)
		}
	</div>
</section>

<CTABanner />
