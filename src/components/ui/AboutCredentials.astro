---
export interface CredentialsContent {
	eyebrow: string;
	title: string;
	description: string;
	designation: string;
	certificate: {
		src: string;
		alt: string;
	};
	logo: {
		src: string;
		alt: string;
	};
}

interface Props extends CredentialsContent {}

const { eyebrow, title, description, designation, certificate, logo } = Astro.props;
---

<section
	class="mt-16 rounded-2xl border border-brand-black/8 bg-brand-warm/80 p-6 sm:p-8 lg:p-10"
	aria-labelledby="about-credentials-heading"
>
	<div class="grid items-center gap-10 lg:grid-cols-12 lg:gap-12">
		<div class="lg:col-span-5">
			<p class="type-eyebrow">{eyebrow}</p>
			<h2 id="about-credentials-heading" class="mt-4 text-2xl font-semibold text-brand-black sm:text-[1.75rem]">
				{title}
			</h2>
			<div class="accent-line mt-5"></div>
			<p class="type-body mt-6 text-brand-black/85">{description}</p>
			<p class="type-caption mt-4 text-brand-charcoal/75">{designation}</p>
			<div class="mt-8 inline-block max-w-[280px] rounded-lg bg-brand-white px-4 py-3 shadow-sm">
				<img
					src={logo.src}
					alt={logo.alt}
					width={560}
					height={160}
					class="h-auto w-full"
					loading="lazy"
					decoding="async"
				/>
			</div>
		</div>

		<div class="lg:col-span-7">
			<figure class="overflow-hidden rounded-xl border border-brand-taupe/25 bg-brand-white shadow-[0_8px_32px_-8px_rgba(44,36,32,0.12)]">
				<img
					src={certificate.src}
					alt={certificate.alt}
					width={1200}
					height={850}
					class="w-full"
					loading="lazy"
					decoding="async"
				/>
			</figure>
		</div>
	</div>
</section>
