---
import { site } from '../../data/site';

// Formspree endpoint — replace PLACEHOLDER in site.ts with your form ID
// Mailto fallback: mailto:{site.email}?subject=Website%20Inquiry
---

<form
	action={site.formspreeEndpoint}
	method="POST"
	class="space-y-5"
>
	<div>
		<label for="name" class="mb-1.5 block text-sm font-medium text-brand-black">Name</label>
		<input
			type="text"
			id="name"
			name="name"
			required
			class="w-full rounded-md border border-brand-black/20 px-4 py-2.5 text-brand-black placeholder:text-brand-black/40 focus:border-brand-red focus:outline-none focus:ring-1 focus:ring-brand-red"
			placeholder="Your name"
		/>
	</div>

	<div>
		<label for="email" class="mb-1.5 block text-sm font-medium text-brand-black">Email</label>
		<input
			type="email"
			id="email"
			name="email"
			required
			class="w-full rounded-md border border-brand-black/20 px-4 py-2.5 text-brand-black placeholder:text-brand-black/40 focus:border-brand-red focus:outline-none focus:ring-1 focus:ring-brand-red"
			placeholder="you@example.com"
		/>
	</div>

	<div>
		<label for="phone" class="mb-1.5 block text-sm font-medium text-brand-black">Phone</label>
		<input
			type="tel"
			id="phone"
			name="phone"
			class="w-full rounded-md border border-brand-black/20 px-4 py-2.5 text-brand-black placeholder:text-brand-black/40 focus:border-brand-red focus:outline-none focus:ring-1 focus:ring-brand-red"
			placeholder="(555) 123-4567"
		/>
	</div>

	<div>
		<label for="message" class="mb-1.5 block text-sm font-medium text-brand-black">Message</label>
		<textarea
			id="message"
			name="message"
			rows="5"
			required
			class="w-full rounded-md border border-brand-black/20 px-4 py-2.5 text-brand-black placeholder:text-brand-black/40 focus:border-brand-red focus:outline-none focus:ring-1 focus:ring-brand-red"
			placeholder="How can I help you?"
		></textarea>
	</div>

	<button
		type="submit"
		class="w-full rounded-md bg-brand-red px-5 py-2.5 text-sm font-medium text-brand-white transition-colors hover:bg-brand-red/90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-red sm:w-auto"
	>
		Send Message
	</button>
</form>
