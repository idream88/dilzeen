---
import SectionHeading from '../ui/SectionHeading.astro';
import DecorativeMotif from '../ui/DecorativeMotif.astro';
import { testimonials } from '../../data/placeholders';

const cardStyles = [
	'md:translate-y-0',
	'md:translate-y-6',
	'md:-translate-y-3',
];
---

<section class="relative overflow-hidden py-20 sm:py-28">
	<div class="absolute inset-0 bg-brand-cream" aria-hidden="true"></div>
	<DecorativeMotif variant="grid" class="left-8 top-32 h-28 w-28 opacity-40" />

	<div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
		<SectionHeading
			eyebrow="Client Stories"
			title="What Clients Say"
			subtitle="Real experiences from buyers, sellers, and relocating families."
		/>
		<div class="mt-14 grid gap-8 md:grid-cols-3" data-reveal-stagger>
			{
				testimonials.slice(0, 3).map((t, index) => (
					<blockquote
						data-reveal="fade"
						class:list={[
							'card-lift group relative rounded-2xl border border-brand-taupe/40 bg-brand-ivory/90 p-8',
							cardStyles[index],
						]}
					>
						<!-- Decorative quote mark -->
						<span
							class="pointer-events-none absolute -top-2 left-6 font-serif text-7xl leading-none text-brand-red/15 select-none"
							aria-hidden="true"
						>
							&ldquo;
						</span>

						<p class="type-body relative z-10 pt-6 italic">
							{t.quote}
						</p>

						<footer class="relative z-10 mt-6 border-t border-brand-beige pt-5">
							<cite class="not-italic">
								<span class="type-body-sm font-semibold text-brand-espresso">{t.name}</span>
								<span class="type-caption">, {t.location}</span>
							</cite>
						</footer>

						<!-- Subtle corner accent -->
						<div
							class="absolute bottom-4 right-4 h-6 w-6 border-b border-r border-brand-red/20 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
							aria-hidden="true"
						></div>
					</blockquote>
				))
			}
		</div>
		<div class="mt-12 text-center" data-reveal>
			<a
				href="/reviews"
				class="link-arrow type-btn inline-flex items-center gap-2 text-brand-red transition-colors hover:text-brand-red-dark"
			>
				Read more reviews
				<svg class="link-arrow-icon h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
				</svg>
			</a>
		</div>
	</div>
</section>
