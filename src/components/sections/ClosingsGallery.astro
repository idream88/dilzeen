---
import type { ClosingPhoto } from '../../data/closings';

interface Props {
	photos: ClosingPhoto[];
}

const { photos } = Astro.props;
---

<div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3" data-reveal-stagger>
	{
		photos.map((photo) => (
			<figure
				data-reveal
				class="gallery-card group card-lift overflow-hidden rounded-2xl border border-brand-taupe/40 bg-brand-ivory/60"
			>
				<div class="img-zoom relative aspect-[4/3] bg-brand-beige/40">
					<img
						src={photo.src}
						alt={photo.alt}
						width={800}
						height={600}
						loading="lazy"
						decoding="async"
						class="h-full w-full object-cover"
					/>
				</div>
				<figcaption class="border-t border-brand-taupe/30 px-5 py-4">
					<p class="gallery-caption type-caption font-medium text-brand-espresso">{photo.caption}</p>
				</figcaption>
			</figure>
		))
	}
</div>
