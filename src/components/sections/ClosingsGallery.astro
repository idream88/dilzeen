---
import type { ClosingPhoto } from '../../data/closings';

interface Props {
	photos: ClosingPhoto[];
}

const { photos } = Astro.props;
---

<div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
	{
		photos.map((photo) => (
			<figure class="group card-lift overflow-hidden rounded-2xl border border-brand-taupe/40 bg-brand-ivory/60 shadow-[0_4px_24px_-8px_rgba(44,36,32,0.08)]">
				<div class="relative aspect-[4/3] overflow-hidden bg-brand-beige/40">
					<img
						src={photo.src}
						alt={photo.alt}
						width={800}
						height={600}
						loading="lazy"
						decoding="async"
						class="h-full w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03]"
					/>
				</div>
				<figcaption class="border-t border-brand-taupe/30 px-5 py-4">
					<p class="type-caption font-medium text-brand-espresso">{photo.caption}</p>
				</figcaption>
			</figure>
		))
	}
</div>
