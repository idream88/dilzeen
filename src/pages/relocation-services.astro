---
import BaseLayout from '../layouts/BaseLayout.astro';
import InnerPageContent from '../components/ui/InnerPageContent.astro';
import { pages } from '../data/placeholders';
import { formatTitle } from '../data/site';

const content = pages['relocation-services'];
---

<BaseLayout title={formatTitle(content.title)} description={content.description}>
	<InnerPageContent content={content} />
</BaseLayout>
