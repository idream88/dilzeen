---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/ui/PageHero.astro';
import ContactForm from '../components/ui/ContactForm.astro';
import { pages } from '../data/placeholders';
import { site, formatTitle, fullStreetAddress } from '../data/site';

const content = pages.contact;

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'RealEstateAgent',
	name: site.name,
	description: site.defaultDescription,
	url: site.url,
	telephone: site.phone,
	email: site.email,
	address: {
		'@type': 'PostalAddress',
		streetAddress: fullStreetAddress(),
		addressLocality: site.address.city,
		addressRegion: site.address.state,
		postalCode: site.address.zip,
		addressCountry: 'US',
	},
	areaServed: site.areaServed,
};
---

<BaseLayout title={formatTitle(content.title)} description={content.description} jsonLd={jsonLd}>
	<PageHero title={content.title} subtitle={content.subtitle} />

	<section class="py-16 sm:py-20">
		<div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
			<div class="grid gap-12 lg:grid-cols-2">
				<div>
					<!-- PLACEHOLDER: replace with client copy -->
					{content.intro.map((paragraph) => <p class="mb-4 text-brand-black/80">{paragraph}</p>)}

					<div class="mt-8 space-y-4 text-brand-black/80">
						<div>
							<p class="text-sm font-semibold uppercase tracking-wider text-brand-black/50">Phone</p>
							<a href={`tel:${site.phone.replace(/\D/g, '')}`} class="text-brand-red hover:underline">
								{site.phone}
							</a>
						</div>
						<div>
							<p class="text-sm font-semibold uppercase tracking-wider text-brand-black/50">Email</p>
							<a href={`mailto:${site.email}`} class="text-brand-red hover:underline">
								{site.email}
							</a>
						</div>
						<div>
							<p class="text-sm font-semibold uppercase tracking-wider text-brand-black/50">Office</p>
							<p>
								{site.address.street}<br />
								{site.address.suite}<br />
								{site.address.city}, {site.address.state} {site.address.zip}
							</p>
						</div>
						<div>
							<p class="text-sm font-semibold uppercase tracking-wider text-brand-black/50">License</p>
							<p>{site.license}</p>
						</div>
						<div>
							<p class="text-sm font-semibold uppercase tracking-wider text-brand-black/50">Hours</p>
							<p>{site.hours}</p>
						</div>
					</div>
				</div>

				<div class="rounded-lg border border-brand-black/10 bg-brand-warm p-6 sm:p-8">
					<h2 class="text-xl font-semibold text-brand-black">Send a Message</h2>
					<p class="mt-2 text-sm text-brand-black/60">
						Fill out the form below and Dilzeen will respond promptly.
					</p>
					<div class="mt-6">
						<ContactForm />
					</div>
				</div>
			</div>
		</div>
	</section>
</BaseLayout>
