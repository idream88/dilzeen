---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeroBanner from '../components/ui/PageHeroBanner.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import { pages, testimonials } from '../data/placeholders';
import { formatTitle } from '../data/site';

const content = pages.reviews;
---

<BaseLayout title={formatTitle(content.title)} description={content.description}>
	<PageHeroBanner title={content.title} subtitle={content.subtitle} image={content.heroImage!} overlay="cream" />

	<section class="relative py-16 sm:py-20">
		<div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
			<div class="max-w-3xl text-brand-black/80">
				{content.intro.map((paragraph) => <p class="mb-4">{paragraph}</p>)}
			</div>

			<div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
				{
					testimonials.map((t) => (
						<blockquote class="rounded-lg border border-brand-black/10 bg-brand-warm p-6">
							<p class="text-brand-black/80">&ldquo;{t.quote}&rdquo;</p>
							<footer class="mt-4 text-sm font-medium text-brand-black">
								{t.name}
								<span class="font-normal text-brand-black/60"> — {t.location}</span>
							</footer>
						</blockquote>
					))
				}
			</div>
		</div>
	</section>

	<CTABanner />
</BaseLayout>
